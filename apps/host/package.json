    "qrcode": "^1.5.0",
    "tweetnacl": "^1.0.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@airloom/channel": "workspace:*",
    "@airloom/crypto": "workspace:*",
    "@airloom/protocol": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/qrcode": "^1.5.0",
    "@types/ws": "^8.5.0"
