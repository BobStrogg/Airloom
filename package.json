{
  "name": "airloom-monorepo",
  "private": true,
  "version": "0.1.1",
  "description": "Secure, E2E encrypted device-to-device streaming relay",
  "scripts": {
    "dev:relay": "tsx packages/relay/src/main.ts",
    "dev:host": "pnpm --filter airloom dev",
    "dev:viewer": "pnpm --filter @airloom/viewer dev",
    "build": "pnpm -r build",
    "build:pages": "pnpm --filter @airloom/viewer build:pages",
    "typecheck": "tsc --build",
    "postinstall": "node scripts/fix-permissions.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "Chris Cavanagh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BobStrogg/Airloom.git"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "router": "1.3.8",
      "call-bound": "1.0.3",
      "get-intrinsic": "1.2.4",
      "side-channel": "1.0.6",
      "side-channel-map": "1.0.5",
      "side-channel-weakmap": "1.0.4"
    }
  }
}
